# Autonomy Agent DinD (Docker-in-Docker) Intermediate Image
# Extends autonomy-agent (Ubuntu 24.04 base) with Docker CE + docker-compose
# for project images that need to run a nested docker daemon (e.g. Anchore
# Enterprise compose stack).
#
# Also bakes in the shared entrypoint wrapper that runs a per-project
# /startup.sh (if mounted) in the background before exec'ing the caller's
# command. launch_session() passes the full claude command via exec "$@", so
# no model strings or CLI args are hardcoded here.
#
# Build:  docker build -f agents/Dockerfile.dind -t autonomy-agent:dind agents/
# Run:    project images FROM this one; invoked via launch_session(privileged=True).

FROM autonomy-agent

USER root

ENV DEBIAN_FRONTEND=noninteractive

# ── Docker CE from the official APT repo (Ubuntu, NOT Alpine) ────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl gnupg lsb-release sudo iptables \
    && install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/ubuntu/gpg \
         | gpg --dearmor -o /etc/apt/keyrings/docker.gpg \
    && chmod a+r /etc/apt/keyrings/docker.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" \
         > /etc/apt/sources.list.d/docker.list \
    && apt-get update && apt-get install -y --no-install-recommends \
        docker-ce docker-ce-cli containerd.io docker-compose-plugin \
    && rm -rf /var/lib/apt/lists/*

# Agent user needs docker group (for the nested daemon socket) and passwordless
# sudo so /startup.sh can run `dockerd` without being root by default.
RUN usermod -aG docker agent \
    && echo 'agent ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/agent \
    && chmod 440 /etc/sudoers.d/agent

# Poetry — common enough across project images (Enterprise NG at minimum)
# that it lives in the shared dind base. Installed system-wide for root and
# the agent user.
RUN pip install --break-system-packages --no-cache-dir poetry

# Override DOCKER_HOST so the client finds the nested daemon by default.
ENV DOCKER_HOST=unix:///var/run/docker.sock

# ── Shared entrypoint wrapper ─────────────────────────────────────────────────
# If /startup.sh is mounted, kick it off in the background, capture its pid,
# and record its exit status. Then exec the caller's command (claude / sh -c).
# launch_session() passes the full argv via exec "$@" — no hardcoded model.
COPY dind-entrypoint.sh /usr/local/bin/autonomy-entrypoint.sh
RUN chmod +x /usr/local/bin/autonomy-entrypoint.sh

USER agent

# Entrypoint does NOT hardcode claude or any model string — launch_session()
# passes the full command (claude + flags + model) via docker CMD, which
# lands on the wrapper as "$@".
ENTRYPOINT ["/usr/local/bin/autonomy-entrypoint.sh"]
